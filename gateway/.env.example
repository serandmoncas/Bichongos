# gateway/.env.example — copiar a .env y completar
# NUNCA subir .env a git

# ─── Telegram Bot ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstuVWXyz
TELEGRAM_CHAT_ID=-100123456789      # ID del grupo o chat personal

# ─── Firebase ──────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=bichongos-iot
FIREBASE_DATABASE_URL=https://bichongos-iot-default-rtdb.firebaseio.com
# Ruta al archivo de credenciales de cuenta de servicio
FIREBASE_CREDENTIALS_PATH=/home/pi/bichongos/gateway/firebase-credentials.json

# ─── InfluxDB ──────────────────────────────────────────────────────────────
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=tu-token-de-influxdb-aqui
INFLUXDB_ORG=bichongos
INFLUXDB_BUCKET=capsulas

# ─── MQTT ──────────────────────────────────────────────────────────────────
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USER=gateway
MQTT_PASS=password_gateway_mqtt
